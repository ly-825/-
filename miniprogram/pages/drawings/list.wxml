<view class="container">
  <view class="header"><view class="title">{{title}}</view><view class="subtitle">查看图纸识别记录，进入详情后可确认字段。</view></view>
  <view class="card">
    <input class="input" placeholder="搜索产品编号、名称或材质" value="{{q}}" bindinput="onSearchInput" />
    <input class="input" type="digit" placeholder="总成品厚度" value="{{product_thickness}}" data-field="product_thickness" bindinput="onFilterInput" />
    <input class="input" type="digit" placeholder="钢板厚度" value="{{plate_thickness}}" data-field="plate_thickness" bindinput="onFilterInput" />
    <button class="btn secondary" bindtap="load">搜索</button>
  </view>
  <view class="card">
    <view wx:if="{{!items.length}}" class="empty">暂无图纸记录</view>
    <view wx:for="{{items}}" wx:key="id" class="list-item" bindtap="goDetail" data-id="{{item.id}}">
      <view class="row"><view class="name">{{item.product_code_text}}</view><view class="badge">{{item.version_text}} {{item.active_text}}</view></view>
      <view class="meta">{{item.product_category_text}}｜{{item.product_name_text}}｜{{item.material_text}}</view>
      <view class="meta">总成品厚度 {{item.product_thickness_text}}｜钢板厚度 {{item.plate_thickness_text}}</view>
      <view wx:if="{{item.remark_text}}" class="meta">备注：{{item.remark_text}}</view>
      <view class="meta">外径 {{item.max_outer_diameter_text}}｜{{item.confirmed_text}}</view>
    </view>
  </view>
</view>
