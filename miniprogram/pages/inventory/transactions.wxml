<view class="container">
  <view class="header">
    <view class="eyebrow">STOCK LEDGER</view>
    <view class="title">库存流水</view>
    <view class="subtitle">产品入库和出库记录。</view>
  </view>

  <view class="card">
    <view class="section-title">最近记录</view>
    <view wx:if="{{!items.length}}" class="empty">暂无库存流水</view>
    <view wx:for="{{items}}" wx:key="id" class="list-item">
      <view class="row">
        <view class="name">{{item.code_text}}</view>
        <view class="badge">{{item.transaction_type}}</view>
      </view>
      <view class="meta">数量 {{item.quantity}}｜{{item.before_quantity}} → {{item.after_quantity}}</view>
      <view class="meta">{{item.operator_name_text}}｜{{item.remark_text}}｜{{item.created_at}}</view>
      <button wx:if="{{item.can_reverse && reverseForm.id !== item.id}}" class="btn secondary" size="mini" data-id="{{item.id}}" bindtap="showReverseForm">撤销</button>
      <view wx:if="{{reverseForm.id === item.id}}" class="reverse-panel">
        <input class="input" placeholder="操作人" value="{{reverseForm.operator_name}}" data-field="operator_name" bindinput="onReverseInput" />
        <input class="input" placeholder="撤销原因（必填）" value="{{reverseForm.remark}}" data-field="remark" bindinput="onReverseInput" />
        <view class="row">
          <button class="btn secondary" size="mini" bindtap="hideReverseForm">取消</button>
          <button class="btn" size="mini" bindtap="reverse" loading="{{reversingId === item.id}}">确认撤销</button>
        </view>
      </view>
      <view wx:if="{{item.reversed_transaction_id}}" class="meta">已撤销/冲销</view>
    </view>
  </view>
</view>
