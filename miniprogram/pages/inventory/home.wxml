<view class="container">
  <view class="header">
    <view class="eyebrow">PRODUCT STOCK</view>
    <view class="title">产品库存</view>
    <view class="subtitle">查看产品库存，按已确认图纸执行入库和出库。</view>
  </view>
  <view class="card stat-card">
    <view class="stat-label">产品可用数量</view>
    <view class="stat-value">{{productQuantity}}</view>
  </view>
  <view class="card">
    <view class="section-title">常用操作</view>
    <view class="menu-item" bindtap="go" data-url="/pages/inventory/list">
      <view><view class="menu-title">库存查询</view><view class="menu-desc">按型号、材质、厚度和库位查询</view></view>
      <view class="arrow">›</view>
    </view>
    <view class="menu-item" bindtap="go" data-url="/pages/inventory/inbound">
      <view><view class="menu-title">产品入库</view><view class="menu-desc">入库后自动生成待入库余料</view></view>
      <view class="arrow">›</view>
    </view>
    <view class="menu-item" bindtap="go" data-url="/pages/inventory/outbound">
      <view><view class="menu-title">产品出库</view><view class="menu-desc">按 FIFO 扣减产品库存</view></view>
      <view class="arrow">›</view>
    </view>
    <view class="menu-item" bindtap="go" data-url="/pages/inventory/transactions">
      <view><view class="menu-title">库存流水</view><view class="menu-desc">查看产品入库和出库记录</view></view>
      <view class="arrow">›</view>
    </view>
  </view>
</view>
