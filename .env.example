APP_NAME=DXF Material Matching MVP
DATABASE_URL=sqlite:///./data/app.db
UPLOAD_DIR=./data/uploads
DRAWING_PREVIEW_DIR=./data/previews
DRAWING_PREVIEW_CONVERTER_PATH=
DRAWING_PREVIEW_CONVERTER_ARGS=-auto-fit -paper=A4 -force -monochrome
DRAWING_PREVIEW_TIMEOUT_SECONDS=90
QRCODE_DIR=./data/qrcodes
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.5-plus
QWEN_FALLBACK_MODEL=qwen3.5-max
THICKNESS_TOLERANCE=0.05
MACHINING_MARGIN=2
MAX_UPLOAD_SIZE_MB=50
ADMIN_ACCESS_TOKEN=
